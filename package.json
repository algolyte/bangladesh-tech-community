{
  "name": "bangladesh-tech-community",
  "version": "1.0.0",
  "private": true,
  "description": "Static developer directory and ecosystem dashboard for Bangladeshi tech professionals.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--no-experimental-webstorage next dev",
    "build": "NODE_OPTIONS=--no-experimental-webstorage next build",
    "build:web": "next build",
    "start": "npx serve@latest out -l 3000",
    "lint": "next lint",
    "validate": "node --import tsx scripts/validate-profiles.ts",
    "build:submitted": "node --import tsx scripts/build-submitted-json.ts",
    "enrich:github": "node --import tsx scripts/enrich-github.ts",
    "enrich:portfolio": "node --import tsx scripts/enrich-portfolio.ts",
    "build:data": "node --import tsx scripts/build-profiles.ts",
    "build:dashboard": "node --import tsx scripts/build-dashboard-data.ts",
    "generate:readme": "node --import tsx scripts/generate-readme.ts",
    "migrate:readme": "node --import tsx scripts/migrate-readme.ts",
    "sync": "node --import tsx scripts/sync-all.ts"
  },
  "dependencies": {
    "next": "15.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.24.2",
    "js-yaml": "4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.15.2",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  }
}
